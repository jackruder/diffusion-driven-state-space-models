# Cluster config — copy to .claude/cluster.local.env and fill in your values.
# cluster.local.env is git-ignored; never commit it.
#
# All three values default reasonably if unset; set them here so that
# monitor.sh, lorenz.sbatch, and Claude skills work without extra flags.

# Your MSU NetID. (ex. a12b456)
CLUSTER_NETID=YOUR_NETID

# Full SSH target for the login node.
CLUSTER_HOST=YOUR_NETID@tempest-login.msu.montana.edu

# Absolute path to the repo on the cluster (use full path, not ~/).
CLUSTER_REMOTE_DIR=/home/YOUR_NETID/diffusion-driven-state-space-models